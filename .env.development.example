# =================================
# Development Environment Configuration
# =================================
# Copy to .env for local development:
# cp .env.development.example .env

# Application
NODE_ENV=development
PORT=3000
HOST=localhost
API_PREFIX=api

# Development Database (Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskdb?schema=public
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskdb

# Development JWT (Not secure - for dev only!)
# Generate new ones: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev-secret-key-change-in-production-min-32-characters-long
JWT_REFRESH_SECRET=dev-refresh-secret-key-change-in-production-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# Redis (Docker)
REDIS_HOST=localhost
REDIS_PORT=6379

# Pagination
PAGINATION_DEFAULT_LIMIT=10
PAGINATION_MAX_LIMIT=100

# Relaxed Rate Limiting for Development
# Higher limits for easier testing
THROTTLE_SHORT_TTL=1000
THROTTLE_SHORT_LIMIT=100
THROTTLE_MEDIUM_TTL=10000
THROTTLE_MEDIUM_LIMIT=500
THROTTLE_LONG_TTL=60000
THROTTLE_LONG_LIMIT=2000

# Verbose Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log
LOG_DIR=logs
LOG_FILE_MAX_SIZE=10485760
LOG_FILE_MAX_FILES=5
LOG_TIMESTAMP_FORMAT=YYYY-MM-DD HH:mm:ss

# CORS - Allow All Origins (Development Only)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:4200

# Security Headers
HELMET_CSP_DEFAULT_SRC=self
HELMET_CSP_STYLE_SRC=self,unsafe-inline
HELMET_CSP_SCRIPT_SRC=self,unsafe-inline
HELMET_CSP_IMG_SRC=self,data:,https:
HELMET_CROSS_ORIGIN_EMBEDDER_POLICY=false

# Health Checks
HEALTH_MEMORY_HEAP_MB=150
HEALTH_MEMORY_RSS_MB=300
HEALTH_DISK_THRESHOLD=0.9
HEALTH_DISK_PATH=/
