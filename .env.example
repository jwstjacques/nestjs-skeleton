# ==============================================
# NestJS API Skeleton - Environment Configuration
# ==============================================
# Copy this file to .env and update values as needed
# All configuration is validated at startup using Zod schemas
# See docs/ENVIRONMENT_VARIABLES.md for detailed documentation

# ==============================================
# Application Configuration
# ==============================================

# Application environment
# TYPE: string
# VALUES: development | staging | production | test
# DEFAULT: development
NODE_ENV=development

# Server port
# TYPE: number
# DEFAULT: 3000
PORT=3000

# ==============================================
# Database Configuration (PostgreSQL)
# ==============================================

# Docker Compose Variables
# These are used by docker-compose.yml to create the PostgreSQL container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskdb
POSTGRES_PORT=5432

# Full database connection URL (recommended)
# TYPE: string (URI)
# FORMAT: postgresql://[user]:[password]@[host]:[port]/[database]?schema=[schema]
# DOCKER: Use localhost when app runs on host, postgres when app runs in Docker
# PRODUCTION: Add ?sslmode=require for SSL connections
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskdb?schema=public

# ⚠️  SECURITY NOTE: Change default passwords in production!
# Use strong, randomly generated passwords for production databases
# Generate secure password: openssl rand -base64 32

# ==============================================
# JWT Authentication
# ==============================================

# Access Token Secret
# TYPE: string
# MIN LENGTH: 32 characters
# SECURITY: Use cryptographically random string in production
# GENERATE: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Refresh Token Secret
# TYPE: string
# MIN LENGTH: 32 characters
# SECURITY: Must be different from JWT_SECRET
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-min-32-chars

# Token Expiration Times
# TYPE: string (time span)
# FORMAT: number + unit (s=seconds, m=minutes, h=hours, d=days)
# EXAMPLES: 15m, 1h, 7d, 30d
# RECOMMENDATION: Short for access (15m-1h), long for refresh (7d-30d)
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ⚠️  PRODUCTION SECURITY:
# - Generate cryptographically secure random secrets (min 32 chars)
# - Use environment-specific secrets (different for dev/staging/prod)
# - Never commit production secrets to version control
# - Rotate secrets periodically

# ==============================================
# Redis Cache Configuration
# ==============================================

# Redis Host
# TYPE: string
# DEFAULT: localhost
# DOCKER: redis (when app runs in Docker network)
REDIS_HOST=localhost

# Redis Port
# TYPE: number
# DEFAULT: 6379
REDIS_PORT=6379

# Note: Cache TTL values are managed via CacheTTL enum in:
# src/common/cache/cache-keys.constants.ts
#
# Module-specific TTLs:
# - User data: 5 minutes
# - Task lists: 30 seconds
# - Statistics: 1 minute
#
# PRODUCTION: Consider Redis password (REDIS_PASSWORD) for security

# ==============================================
# Pagination
# ==============================================

# Default number of items per page
# TYPE: number
# DEFAULT: 10
# RECOMMENDATION: 10-50
PAGINATION_DEFAULT_LIMIT=10

# Maximum items allowed per page (prevents abuse)
# TYPE: number
# DEFAULT: 100
# RECOMMENDATION: 50-200
PAGINATION_MAX_LIMIT=100

# ==============================================
# Rate Limiting (Throttler)
# ==============================================
# Three-tier rate limiting protects against abuse:
# - SHORT: Prevents burst attacks (very short window, low limit)
# - MEDIUM: Sustained request protection (medium window, medium limit)
# - LONG: Overall rate limiting (long window, high limit)

# Short-term (burst protection)
# WINDOW: 1 second
# LIMIT: 10 requests
# PURPOSE: Prevent rapid-fire attacks
THROTTLE_SHORT_TTL=1000
THROTTLE_SHORT_LIMIT=10

# Medium-term (sustained protection)
# WINDOW: 10 seconds
# LIMIT: 50 requests
# PURPOSE: Sustained abuse protection
THROTTLE_MEDIUM_TTL=10000
THROTTLE_MEDIUM_LIMIT=50

# Long-term (overall protection)
# WINDOW: 60 seconds (1 minute)
# LIMIT: 200 requests
# PURPOSE: Overall rate limiting
THROTTLE_LONG_TTL=60000
THROTTLE_LONG_LIMIT=200

# TUNING GUIDE:
# - Public API: Keep restrictive (current values)
# - Internal API: Increase limits 2-3x
# - Development: Can set high limits for testing
# - Load testing: Temporarily increase or disable

# ==============================================
# Logging Configuration
# ==============================================

# Log level: error | warn | info | debug | verbose
# TYPE: string
# DEFAULT: info
# DEVELOPMENT: debug or verbose
# PRODUCTION: warn or error
LOG_LEVEL=debug

# Log file path (relative to project root)
# TYPE: string
# DEFAULT: logs/application.log
LOG_FILE=logs/app.log

# Log directory
# TYPE: string
# DEFAULT: logs
LOG_DIR=logs

# Log file rotation settings
# Maximum file size in bytes (10MB)
LOG_FILE_MAX_SIZE=10485760

# Maximum number of log files to keep
LOG_FILE_MAX_FILES=5

# Timestamp format for log entries
# FORMAT: YYYY-MM-DD HH:mm:ss
LOG_TIMESTAMP_FORMAT=YYYY-MM-DD HH:mm:ss

# ==============================================
# CORS (Cross-Origin Resource Sharing)
# ==============================================

# Allowed origins (comma-separated)
# TYPE: string
# DEVELOPMENT: http://localhost:3000,http://localhost:3001
# PRODUCTION: https://yourdomain.com,https://app.yourdomain.com
# NOTE: Never use * in production
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ==============================================
# Security Headers (Helmet)
# ==============================================

# Content Security Policy directives (comma-separated)
# See: https://developer.mozilla.org/en-US/docs/Web/HTTP/CSP
HELMET_CSP_DEFAULT_SRC=self
HELMET_CSP_STYLE_SRC=self,unsafe-inline
HELMET_CSP_SCRIPT_SRC=self,unsafe-inline
HELMET_CSP_IMG_SRC=self,data:,https:

# Cross-Origin Embedder Policy
# TYPE: boolean
# DEFAULT: false (disabled for Swagger compatibility)
HELMET_CROSS_ORIGIN_EMBEDDER_POLICY=false

# ==============================================
# Health Checks
# ==============================================

# Memory thresholds
# Maximum heap memory in MB before health check fails
# TYPE: number
# DEFAULT: 150
HEALTH_MEMORY_HEAP_MB=150

# Maximum RSS memory in MB before health check fails
# TYPE: number
# DEFAULT: 300
HEALTH_MEMORY_RSS_MB=300

# Disk usage threshold
# Maximum disk usage percentage (0.9 = 90%)
# TYPE: number (0.0 to 1.0)
# DEFAULT: 0.9
HEALTH_DISK_THRESHOLD=0.9

# Disk path to monitor
# TYPE: string
# DEFAULT: / (root filesystem)
HEALTH_DISK_PATH=/

# ==============================================
# Docker Compose Integration
# ==============================================
# When using Docker Compose (npm run docker:start):
# - PostgreSQL is available at localhost:5432
# - Redis is available at localhost:6379
# - PgAdmin UI at http://localhost:5050
#
# Docker containers use the POSTGRES_* variables above
# The app running on your host uses DATABASE_URL
#
# For app inside Docker network, change:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/taskdb?schema=public
# REDIS_HOST=redis

# ==============================================
# CI/CD Configuration
# ==============================================
# For continuous integration/deployment:
#
# Required in CI environment:
# - DATABASE_URL (test database)
# - JWT_SECRET (can be dummy for tests)
# - JWT_REFRESH_SECRET (can be dummy for tests)
# - NODE_ENV=test
#
# Optional:
# - SKIP_DB_SETUP=true (if CI handles DB separately)
# - CI=true (auto-detected by most CI systems)
#
# See docs/TESTING.md for CI/CD configuration examples

# ==============================================
# Example Module Configuration
# ==============================================
# The Tasks module is included as a reference implementation.
# No specific environment variables required.
#
# When you add your own modules, add their configuration here:
# CUSTOM_MODULE_API_KEY=your-key
# CUSTOM_MODULE_ENDPOINT=https://api.example.com

# ==============================================
# Production Security Checklist
# ==============================================
# Before deploying to production:
#
# ☐ Change NODE_ENV to 'production'
# ☐ Generate strong random JWT secrets (min 32 chars)
# ☐ Use production database with SSL enabled
# ☐ Set CORS_ORIGIN to your specific domain(s)
# ☐ Set LOG_LEVEL to 'warn' or 'error'
# ☐ Review and adjust rate limiting thresholds
# ☐ Use Redis password if Redis is exposed
# ☐ Enable HTTPS/TLS for all connections
# ☐ Use secrets manager (AWS Secrets Manager, Azure Key Vault)
# ☐ Enable database connection pooling
# ☐ Review and remove any debug/development settings
# ☐ Configure monitoring and alerting
#
# See docs/PRODUCTION.md for complete deployment guide

# ==============================================
# Optional: Advanced Configuration
# ==============================================
# Uncomment and configure as needed for your application

# API Documentation (Swagger)
# SWAGGER_ENABLED=true
# SWAGGER_PATH=docs

# Application Metrics
# METRICS_ENABLED=false
# METRICS_PORT=9090

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@yourdomain.com

# File Upload
# MAX_FILE_SIZE=5242880  # 5MB in bytes
# ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf
# UPLOAD_DIR=./uploads

# External Services
# EXTERNAL_API_KEY=your-api-key
# EXTERNAL_API_URL=https://api.external-service.com

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
