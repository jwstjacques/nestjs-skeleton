# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database (Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskdb
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskdb?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# Redis (Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600  # Default cache TTL in seconds (1 hour)

# Cache TTL (Time To Live) in milliseconds
CACHE_TTL_LIST=60000      # List endpoints: 60 seconds
CACHE_TTL_SINGLE=300000   # Single item: 300 seconds (5 minutes)

# Pagination
PAGINATION_DEFAULT_LIMIT=10
PAGINATION_MAX_LIMIT=100

# Rate Limiting (Throttler)
# Three-tier rate limiting: short (burst), medium (sustained), long (overall)
THROTTLE_SHORT_TTL=1000
THROTTLE_SHORT_LIMIT=10
THROTTLE_MEDIUM_TTL=10000
THROTTLE_MEDIUM_LIMIT=50
THROTTLE_LONG_TTL=60000
THROTTLE_LONG_LIMIT=200

# Logging
LOG_LEVEL=debug
LOG_DIR=logs
LOG_FILE_MAX_SIZE=10485760  # 10MB in bytes
LOG_FILE_MAX_FILES=5
LOG_TIMESTAMP_FORMAT=YYYY-MM-DD HH:mm:ss

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Helmet Security Headers
# Content Security Policy directives (comma-separated)
HELMET_CSP_DEFAULT_SRC='self'
HELMET_CSP_STYLE_SRC='self','unsafe-inline'
HELMET_CSP_SCRIPT_SRC='self','unsafe-inline'
HELMET_CSP_IMG_SRC='self',data:,https:
HELMET_CROSS_ORIGIN_EMBEDDER_POLICY=false

# Health Checks
HEALTH_MEMORY_HEAP_MB=150        # Max heap memory in MB before health check fails
HEALTH_MEMORY_RSS_MB=300         # Max RSS memory in MB before health check fails
HEALTH_DISK_THRESHOLD=0.9        # Max disk usage percentage (0.9 = 90%)
HEALTH_DISK_PATH=/               # Disk path to monitor

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
