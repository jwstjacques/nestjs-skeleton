# Pagination

# JWT secret keys - MUST be changed in production

# Minimum 32 characters recommended# API version (e.g., "1" for /api/v1)PAGINATION_DEFAULT_LIMIT=10

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-min-32-charsAPI_VERSION=1PAGINATION_MAX_LIMIT=100



# Token expiration times

# Format: 1d (1 day), 7d (7 days), 30d (30 days), 1h (1 hour), etc.

JWT_EXPIRES_IN=1h# ==============================================# Rate Limiting (Throttler)

JWT_REFRESH_EXPIRES_IN=7d

# Database Configuration (PostgreSQL)# Three-tier rate limiting: short (burst), medium (sustained), long (overall)

# ⚠️  SECURITY NOTE: 

# - Generate cryptographically secure random secrets in production# ==============================================THROTTLE_SHORT_TTL=1000

# - Use environment-specific secrets (different for dev/staging/prod)

# - Never commit production secrets to version controlTHROTTLE_SHORT_LIMIT=10

# - Rotate secrets periodically

# Full database connection URL (recommended)THROTTLE_MEDIUM_TTL=10000

# ==============================================

# Redis Cache Configuration# Format: postgresql://user:password@host:port/databaseTHROTTLE_MEDIUM_LIMIT=50

# ==============================================

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskdb?schema=publicTHROTTLE_LONG_TTL=60000

# Redis connection

REDIS_HOST=localhostTHROTTLE_LONG_LIMIT=200

REDIS_PORT=6379

