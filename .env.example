# Pagination Defaults

# ==============================================POSTGRES_PORT=5432LOG_FILE=logs/app.log



# Default number of items per pagePOSTGRES_USER=postgresLOG_DIR=logs

PAGINATION_DEFAULT_LIMIT=10

POSTGRES_PASSWORD=postgresLOG_FILE_MAX_SIZE=10485760  # 10MB in bytes

# Maximum items allowed per page (prevents abuse)

PAGINATION_MAX_LIMIT=100POSTGRES_DB=taskdbLOG_FILE_MAX_FILES=5



# ==============================================LOG_TIMESTAMP_FORMAT=YYYY-MM-DD HH:mm:ss

# Rate Limiting (Throttler)

# ==============================================# Enable SSL for database connection

# Three-tier rate limiting protects against abuse:

# - SHORT: Prevents burst attacks (very short window, low limit)# Set to "true" for production databases# CORS

# - MEDIUM: Sustained request protection (medium window, medium limit)

# - LONG: Overall rate limiting (long window, high limit)DATABASE_SSL=falseCORS_ORIGIN=http://localhost:3000,http://localhost:3001



# Short-term (burst protection)

# 10 requests per 1 second

THROTTLE_SHORT_TTL=1000# ==============================================# Helmet Security Headers

THROTTLE_SHORT_LIMIT=10

# Cache Configuration (Redis)# Content Security Policy directives (comma-separated)

# Medium-term (sustained protection)

# 50 requests per 10 seconds# ==============================================HELMET_CSP_DEFAULT_SRC=self

THROTTLE_MEDIUM_TTL=10000

THROTTLE_MEDIUM_LIMIT=50HELMET_CSP_STYLE_SRC=self,unsafe-inline



# Long-term (overall protection)# Redis server hostHELMET_CSP_SCRIPT_SRC=self,unsafe-inline

# 200 requests per 60 seconds

THROTTLE_LONG_TTL=60000REDIS_HOST=localhostHELMET_CSP_IMG_SRC=self,data:,https:

THROTTLE_LONG_LIMIT=200

HELMET_CROSS_ORIGIN_EMBEDDER_POLICY=false

# Adjust these values based on your API usage patterns

# More restrictive for public APIs, less for internal services# Redis server port



# ==============================================REDIS_PORT=6379# Health Checks

# Logging Configuration

# ==============================================HEALTH_MEMORY_HEAP_MB=150        # Max heap memory in MB before health check fails



# Log level: error | warn | info | debug | verbose# Redis password (leave empty if no password)HEALTH_MEMORY_RSS_MB=300         # Max RSS memory in MB before health check fails

# Production: use 'warn' or 'error'

# Development: use 'debug' or 'verbose'REDIS_PASSWORD=HEALTH_DISK_THRESHOLD=0.9        # Max disk usage percentage (0.9 = 90%)

LOG_LEVEL=debug

HEALTH_DISK_PATH=/               # Disk path to monitor

# Log file path (relative to project root)

LOG_FILE=logs/application.log# Redis database number (0-15)



# Log directoryREDIS_DB=0# Swagger

LOG_DIR=logs

SWAGGER_ENABLED=true

# ==============================================

# CORS Configuration# ==============================================SWAGGER_PATH=api/docs

# ==============================================

# Uncomment and configure for production# Cache TTL (Time To Live) Configuration

# ==============================================

# Allowed origins (comma-separated)# All values in milliseconds

# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com# These define caching durations for different data types



# Allow credentials (cookies, authorization headers)# Very short: 30 seconds (real-time data)

# CORS_CREDENTIALS=trueCACHE_TTL_VERY_SHORT=30000



# ==============================================# Short: 1 minute (frequently changing data)

# Example Module ConfigurationCACHE_TTL_SHORT=60000

# ==============================================

# The Tasks module is included as an example.# Medium: 5 minutes (moderately stable data)

# You can remove it or use it as a reference for building your own modules.CACHE_TTL_MEDIUM=300000

# See docs/CUSTOMIZATION.md for removal instructions.

# Long: 15 minutes (stable data)

# No environment variables are specifically required for the Tasks module.CACHE_TTL_LONG=900000

# This section demonstrates where you would add custom module configuration.

# Very long: 30 minutes (rarely changing data)

# Example custom module env vars:CACHE_TTL_VERY_LONG=1800000

# CUSTOM_MODULE_API_KEY=your-api-key

# CUSTOM_MODULE_ENDPOINT=https://api.example.com# Hour: 1 hour (static reference data)

CACHE_TTL_HOUR=3600000

# ==============================================

# Production Security Checklist# Day: 24 hours (very static data)

# ==============================================CACHE_TTL_DAY=86400000

# Before deploying to production:

# ☐ Change all default passwords# ==============================================

# ☐ Generate strong random JWT secrets (min 32 chars)# Security - JWT Configuration

# ☐ Set NODE_ENV=production# ==============================================

# ☐ Use environment-specific DATABASE_URL

# ☐ Configure CORS_ORIGINS to your domain# JWT secret key (minimum 32 characters)

# ☐ Set LOG_LEVEL=warn or error# IMPORTANT: Generate a strong random key for production

# ☐ Enable HTTPS/TLS# Example: openssl rand -base64 32

# ☐ Review rate limit settingsJWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# ☐ Set secure Redis password if exposed

# ☐ Use secrets manager (AWS Secrets Manager, Azure Key Vault, etc.)# Access token expiration (examples: 15m, 1h, 1d)

# ☐ Enable database SSL/TLSJWT_EXPIRES_IN=7d

# ☐ Review and update token expiration times

# JWT refresh token secret (minimum 32 characters)

# See docs/PRODUCTION.md for complete production deployment guide# IMPORTANT: Must be different from JWT_SECRET

JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-min-32-chars

# Refresh token expiration (examples: 7d, 30d)
JWT_REFRESH_EXPIRES_IN=30d

# ==============================================
# Security - CORS Configuration
# ==============================================

# Allowed CORS origins
# Options:
#   - "*" for all origins (development only!)
#   - Single origin: "https://example.com"
#   - Multiple: "https://app.example.com,https://admin.example.com"
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Allow credentials (cookies, authorization headers)
# Set to "true" or "false"
CORS_CREDENTIALS=true

# ==============================================
# Security - Helmet (HTTP Security Headers)
# ==============================================

# Enable Content Security Policy
# Set to "false" to disable CSP entirely
HELMET_CSP_ENABLED=true

# CSP: default-src directive (comma-separated)
# Controls default source for all content types
HELMET_CSP_DEFAULT_SRC=self

# CSP: style-src directive (comma-separated)
# unsafe-inline needed for some UI libraries
HELMET_CSP_STYLE_SRC=self,unsafe-inline

# CSP: script-src directive (comma-separated)
# unsafe-inline needed for some UI libraries
HELMET_CSP_SCRIPT_SRC=self,unsafe-inline

# CSP: img-src directive (comma-separated)
# Allows images from same origin, data URLs, and HTTPS
HELMET_CSP_IMG_SRC=self,data:,https:

# Cross-Origin-Embedder-Policy (true/false)
# Set to "true" to require CORP for cross-origin resources
HELMET_CROSS_ORIGIN_EMBEDDER_POLICY=false

# Cross-Origin-Opener-Policy (true/false)
# Set to "true" to isolate browsing context
HELMET_CROSS_ORIGIN_OPENER_POLICY=false

# Cross-Origin-Resource-Policy (true/false)
# Set to "true" to prevent cross-origin resource loading
HELMET_CROSS_ORIGIN_RESOURCE_POLICY=false

# ==============================================
# Observability - Logging Configuration
# ==============================================

# Logging level
# Options: error | warn | info | http | verbose | debug | silly
# Production: info or warn
# Development: debug
LOG_LEVEL=debug

# Log files directory
LOG_DIR=logs

# Maximum size of each log file in bytes
# Default: 10MB (10485760 bytes)
LOG_FILE_MAX_SIZE=10485760

# Maximum number of log files to keep (rotation)
LOG_FILE_MAX_FILES=5

# Timestamp format for logs
# Uses moment.js format strings
LOG_TIMESTAMP_FORMAT=YYYY-MM-DD HH:mm:ss

# Application log filename
LOG_APP_FILENAME=application.log

# Error log filename (errors only)
LOG_ERROR_FILENAME=error.log

# ==============================================
# Observability - Health Check Configuration
# ==============================================

# Memory heap threshold in MB
# Health check fails if heap exceeds this value
HEALTH_MEMORY_HEAP_MB=150

# Memory RSS (Resident Set Size) threshold in MB
# Health check fails if RSS exceeds this value
HEALTH_MEMORY_RSS_MB=300

# Disk usage threshold (0.0 to 1.0)
# 0.9 = 90% disk usage triggers health check failure
HEALTH_DISK_THRESHOLD=0.9

# Disk path to monitor for health checks
HEALTH_DISK_PATH=/

# ==============================================
# Rate Limiting (Throttle) Configuration
# ==============================================
# Four-tier rate limiting system

# Short window: Burst protection
# TTL in milliseconds (1 second)
THROTTLE_SHORT_TTL=1000
# Maximum requests in short window
THROTTLE_SHORT_LIMIT=10

# Medium window: Sustained usage
# TTL in milliseconds (10 seconds)
THROTTLE_MEDIUM_TTL=10000
# Maximum requests in medium window
THROTTLE_MEDIUM_LIMIT=50

# Long window: Overall limit
# TTL in milliseconds (60 seconds / 1 minute)
THROTTLE_LONG_TTL=60000
# Maximum requests in long window
THROTTLE_LONG_LIMIT=200

# Strict window: Critical/sensitive operations
# TTL in milliseconds (1 second)
THROTTLE_STRICT_TTL=1000
# Maximum requests in strict window (very limited)
THROTTLE_STRICT_LIMIT=5

# ==============================================
# Pagination Configuration
# ==============================================

# Default number of items per page
PAGINATION_DEFAULT_LIMIT=10

# Maximum allowed items per page
# Prevents excessive data retrieval
PAGINATION_MAX_LIMIT=100

# Default page number (usually 1)
PAGINATION_DEFAULT_PAGE=1

# ==============================================
# API Documentation (Swagger/OpenAPI)
# ==============================================

# Enable Swagger documentation UI
# Set to "false" to disable in production
SWAGGER_ENABLED=true

# Swagger UI path (e.g., "docs" for /api/v1/docs)
SWAGGER_PATH=docs

# API documentation title
SWAGGER_TITLE=NestJS Skeleton API

# API documentation description
SWAGGER_DESCRIPTION=A production-ready NestJS REST API skeleton with best practices

# API version displayed in documentation
SWAGGER_VERSION=1.0

# API contact information
SWAGGER_CONTACT_NAME=API Support
SWAGGER_CONTACT_EMAIL=support@example.com
SWAGGER_CONTACT_URL=https://github.com/jwstjacques/nestjs-skeleton

# ==============================================
# Production Checklist
# ==============================================
#
# Before deploying to production, ensure:
#
# [ ] NODE_ENV=production
# [ ] Generate strong JWT_SECRET and JWT_REFRESH_SECRET (32+ chars)
# [ ] Set specific CORS_ORIGIN (never use "*")
# [ ] Enable DATABASE_SSL=true
# [ ] Set SWAGGER_ENABLED=false (or protect with authentication)
# [ ] Use LOG_LEVEL=info or warn
# [ ] Configure proper health check thresholds
# [ ] Adjust rate limits based on load testing
# [ ] Secure Redis with REDIS_PASSWORD
# [ ] Use environment-specific DATABASE_URL
# [ ] Review and tighten Helmet security headers
#
# ==============================================
# Development Tips
# ==============================================
#
# - Copy this file to .env: cp .env.example .env
# - Never commit .env to version control
# - Use different .env files for dev/staging/production
# - Test configuration changes in development first
# - Monitor logs and health endpoints regularly
# - See docs/CONFIGURATION.md for detailed guide
#
# ==============================================
