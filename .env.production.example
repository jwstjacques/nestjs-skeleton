# =================================
# Production Environment Configuration
# =================================
# ⚠️ SECURITY WARNING: Use secrets manager in production!
# Do not hardcode sensitive values in this file.
# Use environment variables or secrets manager (AWS Secrets Manager, Azure Key Vault, etc.)

# Application
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
API_PREFIX=api

# Production Database
# ⚠️ Use environment variables or secrets manager
# Add ?sslmode=require for SSL connections
DATABASE_URL=${DATABASE_URL}
POSTGRES_HOST=${POSTGRES_HOST}
POSTGRES_PORT=5432
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=${POSTGRES_DB}

# JWT Configuration
# ⚠️ Generate strong random secrets: openssl rand -hex 32
# NEVER use development secrets in production!
JWT_SECRET=${JWT_SECRET}
JWT_REFRESH_SECRET=${JWT_REFRESH_SECRET}
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis Configuration
# ⚠️ Use password-protected Redis in production
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD}

# Pagination
PAGINATION_DEFAULT_LIMIT=10
PAGINATION_MAX_LIMIT=50

# Production Rate Limiting
# Keep restrictive to prevent abuse
THROTTLE_SHORT_TTL=1000
THROTTLE_SHORT_LIMIT=10
THROTTLE_MEDIUM_TTL=10000
THROTTLE_MEDIUM_LIMIT=50
THROTTLE_LONG_TTL=60000
THROTTLE_LONG_LIMIT=200

# Production Logging
# Use warn/error level and JSON format for log aggregation
LOG_LEVEL=warn
LOG_FILE=/var/log/app/application.log
LOG_DIR=/var/log/app
LOG_FILE_MAX_SIZE=10485760
LOG_FILE_MAX_FILES=10
LOG_TIMESTAMP_FORMAT=YYYY-MM-DD HH:mm:ss

# CORS - Specific Origins Only
# ⚠️ NEVER use * in production
CORS_ORIGIN=https://yourdomain.com,https://app.yourdomain.com

# Security Headers - Full Protection
HELMET_CSP_DEFAULT_SRC=self
HELMET_CSP_STYLE_SRC=self
HELMET_CSP_SCRIPT_SRC=self
HELMET_CSP_IMG_SRC=self,data:,https:
HELMET_CROSS_ORIGIN_EMBEDDER_POLICY=true

# Health Checks
HEALTH_MEMORY_HEAP_MB=300
HEALTH_MEMORY_RSS_MB=600
HEALTH_DISK_THRESHOLD=0.85
HEALTH_DISK_PATH=/

# =================================
# Production Deployment Checklist
# =================================
# ☐ All secrets stored in secrets manager
# ☐ DATABASE_URL includes ?sslmode=require
# ☐ CORS_ORIGIN set to specific domains
# ☐ LOG_LEVEL set to warn or error
# ☐ REDIS_PASSWORD configured
# ☐ HOST set to 0.0.0.0 (if containerized)
# ☐ JWT secrets are strong and unique
# ☐ Monitoring and alerting configured
# ☐ SSL/TLS enabled for all connections
# ☐ Database backups configured
