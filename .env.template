# =================================
# NestJS API Skeleton Configuration Template
# =================================
#
# This is a comprehensive template for environment configuration.
# Copy this file to .env and update values for your environment.
#
# Documentation: See docs/ENVIRONMENT_VARIABLES.md for detailed explanations
#
# SECURITY WARNING: Never commit .env files to version control!
# Add .env to .gitignore (already done in this skeleton)

# =================================
# QUICK START (Development)
# =================================
# 1. Copy: cp .env.template .env
# 2. Update DATABASE_URL with your database
# 3. Generate JWT secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 4. Start Docker: npm run docker:start
# 5. Run migrations: npm run prisma:migrate:dev
# 6. Start app: npm run start:dev

# =================================
# Application Settings
# =================================

# Environment
# TYPE: string
# VALUES: development | staging | production | test
# REQUIRED: Yes
# DEFAULT: development
NODE_ENV=development

# Server Configuration
# TYPE: number
# REQUIRED: Yes
# DEFAULT: 3000
PORT=3000

# TYPE: string
# REQUIRED: No
# DEFAULT: localhost
# PRODUCTION: Set to 0.0.0.0 to accept connections from any host
HOST=localhost

# API Versioning
# TYPE: string
# REQUIRED: Yes
# DEFAULT: api/v1
# INFO: Prefix for all API routes (e.g., /api/v1/tasks)
API_PREFIX=api

# =================================
# Database Configuration (PostgreSQL)
# =================================

# Full Connection URL (Recommended)
# TYPE: string (URI)
# REQUIRED: Yes
# FORMAT: postgresql://[user]:[password]@[host]:[port]/[database]?schema=[schema]
# EXAMPLE: postgresql://postgres:postgres@localhost:5432/mydb?schema=public
#
# IMPORTANT:
# - For Docker: host = localhost (app on host) or postgres (app in Docker)
# - For production: Use environment-specific credentials
# - Always use SSL in production: ?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskdb?schema=public

# Individual Components (Used by Docker Compose)
# These are also used if DATABASE_URL components need override
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskdb

# Database Connection Pool
# TYPE: number
# REQUIRED: No
# DEFAULT: 10
# DB_POOL_SIZE=10

# =================================
# JWT Authentication
# =================================

# Access Token Secret
# TYPE: string
# REQUIRED: Yes
# MIN LENGTH: 32 characters
# SECURITY: Use cryptographically random string in production
# GENERATE: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MIN_32_CHARACTERS

# Refresh Token Secret
# TYPE: string
# REQUIRED: Yes
# MIN LENGTH: 32 characters
# SECURITY: Must be different from JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_STRING_MIN_32_CHARS

# Token Expiration
# TYPE: string (time span)
# REQUIRED: Yes
# FORMAT: number + unit (s=seconds, m=minutes, h=hours, d=days)
# EXAMPLES: 15m, 1h, 7d, 30d
# RECOMMENDATION: Short for access (15m-1h), long for refresh (7d-30d)
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Token Issuer (Optional)
# TYPE: string
# REQUIRED: No
# JWT_ISSUER=your-app-name

# Token Audience (Optional)
# TYPE: string
# REQUIRED: No
# JWT_AUDIENCE=your-app-users

# =================================
# Redis Cache Configuration
# =================================

# Redis Host
# TYPE: string
# REQUIRED: Yes (if caching enabled)
# DEFAULT: localhost
# DOCKER: redis (when app runs in Docker network)
REDIS_HOST=localhost

# Redis Port
# TYPE: number
# REQUIRED: Yes
# DEFAULT: 6379
REDIS_PORT=6379

# Redis Password (Optional)
# TYPE: string
# REQUIRED: No (required in production)
# REDIS_PASSWORD=your-redis-password

# Redis Database
# TYPE: number (0-15)
# REQUIRED: No
# DEFAULT: 0
# REDIS_DB=0

# Default Cache TTL
# TYPE: number (milliseconds)
# REQUIRED: No
# DEFAULT: 30000 (30 seconds)
# NOTE: Module-specific TTLs defined in src/common/cache/cache-keys.constants.ts
REDIS_TTL=30000

# =================================
# Rate Limiting (Throttler)
# =================================

# Three-tier rate limiting for DDoS protection:
# - SHORT: Prevents burst attacks
# - MEDIUM: Sustained request protection
# - LONG: Overall rate limiting

# Short-term Throttle (Burst Protection)
# WINDOW: 1 second
# LIMIT: 10 requests
# PURPOSE: Prevent rapid-fire attacks
THROTTLE_SHORT_TTL=1000
THROTTLE_SHORT_LIMIT=10

# Medium-term Throttle
# WINDOW: 10 seconds
# LIMIT: 50 requests
# PURPOSE: Sustained abuse protection
THROTTLE_MEDIUM_TTL=10000
THROTTLE_MEDIUM_LIMIT=50

# Long-term Throttle
# WINDOW: 60 seconds (1 minute)
# LIMIT: 200 requests
# PURPOSE: Overall rate limiting
THROTTLE_LONG_TTL=60000
THROTTLE_LONG_LIMIT=200

# TUNING GUIDE:
# - Public API: Keep restrictive (current values)
# - Internal API: Increase limits 2-3x
# - Development: Can disable or set high limits
# - Load testing: Temporarily increase or disable

# =================================
# Pagination
# =================================

# Default Page Size
# TYPE: number
# REQUIRED: No
# DEFAULT: 10
# RECOMMENDATION: 10-50
PAGINATION_DEFAULT_LIMIT=10

# Maximum Page Size
# TYPE: number
# REQUIRED: No
# DEFAULT: 100
# PURPOSE: Prevent database overload
# RECOMMENDATION: 50-200
PAGINATION_MAX_LIMIT=100

# =================================
# Logging
# =================================

# Log Level
# TYPE: string
# VALUES: error | warn | info | debug | verbose
# REQUIRED: No
# DEFAULT: info
# DEVELOPMENT: debug or verbose
# PRODUCTION: warn or error
LOG_LEVEL=debug

# Log File Path
# TYPE: string (file path)
# REQUIRED: No
# DEFAULT: logs/application.log
LOG_FILE=logs/app.log

# Log Directory
# TYPE: string (directory path)
# REQUIRED: No
# DEFAULT: logs
LOG_DIR=logs

# Log File Rotation
# Maximum file size in bytes (10MB)
LOG_FILE_MAX_SIZE=10485760

# Maximum number of log files to keep
LOG_FILE_MAX_FILES=5

# Timestamp format
LOG_TIMESTAMP_FORMAT=YYYY-MM-DD HH:mm:ss

# Structured Logging (JSON)
# TYPE: boolean
# REQUIRED: No
# DEFAULT: false
# PRODUCTION: true (for log aggregation)
# LOG_FORMAT=json

# =================================
# CORS (Cross-Origin Resource Sharing)
# =================================

# Allowed Origins
# TYPE: string (comma-separated URLs)
# REQUIRED: No (required in production)
# DEVELOPMENT: http://localhost:3000,http://localhost:3001
# PRODUCTION: Specific domains only
# EXAMPLES:
#   - Single: https://yourdomain.com
#   - Multiple: https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Allow Credentials
# TYPE: boolean
# REQUIRED: No
# DEFAULT: true
# NOTE: Required for cookies and Authorization headers
# CORS_CREDENTIALS=true

# =================================
# Security Headers (Helmet)
# =================================

# Content Security Policy
# See: https://developer.mozilla.org/en-US/docs/Web/HTTP/CSP
HELMET_CSP_DEFAULT_SRC=self
HELMET_CSP_STYLE_SRC=self,unsafe-inline
HELMET_CSP_SCRIPT_SRC=self,unsafe-inline
HELMET_CSP_IMG_SRC=self,data:,https:

# Cross-Origin Embedder Policy
# TYPE: boolean
# DEFAULT: false (disabled for Swagger compatibility)
HELMET_CROSS_ORIGIN_EMBEDDER_POLICY=false

# =================================
# Health Checks
# =================================

# Memory thresholds
# Maximum heap memory in MB before health check fails
HEALTH_MEMORY_HEAP_MB=150

# Maximum RSS memory in MB before health check fails
HEALTH_MEMORY_RSS_MB=300

# Disk usage threshold (0.9 = 90%)
HEALTH_DISK_THRESHOLD=0.9

# Disk path to monitor
HEALTH_DISK_PATH=/

# =================================
# API Documentation (Swagger)
# =================================

# Enable Swagger UI
# TYPE: boolean
# REQUIRED: No
# DEFAULT: true
# PRODUCTION: false (or restrict access)
# SWAGGER_ENABLED=true

# Swagger Path
# TYPE: string
# REQUIRED: No
# DEFAULT: docs
# ACCESS: http://localhost:3000/api/v1/docs
# SWAGGER_PATH=docs

# =================================
# Example Module Configuration
# =================================
# The Tasks module is included as a reference implementation.
# No specific environment variables required.
#
# When you add your own modules, add their configuration here:
# CUSTOM_MODULE_API_KEY=your-key
# CUSTOM_MODULE_ENDPOINT=https://api.example.com

# =================================
# Optional: External Services
# =================================

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# EMAIL_FROM=noreply@yourdomain.com

# File Storage (AWS S3, Azure Blob, etc.)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# Payment Processing
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...

# Analytics
# GOOGLE_ANALYTICS_ID=UA-XXXXX-Y

# =================================
# Production Deployment Checklist
# =================================
# Before deploying to production:
#
# ☐ Change NODE_ENV to 'production'
# ☐ Generate strong random JWT secrets (min 32 chars)
# ☐ Use production database with SSL enabled
# ☐ Set CORS_ORIGIN to your specific domain(s)
# ☐ Set LOG_LEVEL to 'warn' or 'error'
# ☐ Disable SWAGGER_ENABLED or protect with authentication
# ☐ Enable HELMET security headers
# ☐ Review and adjust rate limiting thresholds
# ☐ Use Redis password (REDIS_PASSWORD)
# ☐ Enable database connection pooling
# ☐ Set HOST=0.0.0.0 for containerized deployments
# ☐ Use secrets manager (AWS Secrets Manager, Azure Key Vault)
# ☐ Enable SSL/TLS for all connections
# ☐ Review and remove any debug/development settings
# ☐ Backup DATABASE_URL in secure location
# ☐ Configure monitoring and alerting
#
# See docs/PRODUCTION.md for complete deployment guide

# =================================
# CI/CD Configuration
# =================================
# For continuous integration/deployment:
#
# Required in CI environment:
# - DATABASE_URL (test database)
# - JWT_SECRET (can be dummy for tests)
# - JWT_REFRESH_SECRET (can be dummy for tests)
# - NODE_ENV=test
#
# Optional:
# - SKIP_DB_SETUP=true (if CI handles DB separately)
# - CI=true (auto-detected by most CI systems)
# - REDIS_HOST (if using Redis in CI)
#
# See docs/TESTING.md for CI/CD configuration examples

# =================================
# Docker Configuration Notes
# =================================
# When using Docker Compose (npm run docker:start):
#
# Services created:
# - postgres: PostgreSQL database (port 5432)
# - redis: Redis cache (port 6379)
# - pgadmin: Database admin UI (port 5050)
#
# For app on host machine:
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskdb?schema=public
#   REDIS_HOST=localhost
#
# For app inside Docker network:
#   DATABASE_URL=postgresql://postgres:postgres@postgres:5432/taskdb?schema=public
#   REDIS_HOST=redis
#
# PgAdmin access:
#   URL: http://localhost:5050
#   Email: admin@admin.com
#   Password: admin

# =================================
# END OF CONFIGURATION
# =================================
