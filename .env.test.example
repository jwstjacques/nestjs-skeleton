# =================================
# Test Environment Configuration
# =================================
# Used by automated tests (unit + E2E)
# CI/CD systems should override with their own values

# Application
NODE_ENV=test
PORT=3001
HOST=localhost
API_PREFIX=api/v1

# Test Database
# Separate database to avoid polluting development data
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskdb_test?schema=public
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskdb_test

# Test JWT (Dummy values OK for testing)
JWT_SECRET=test-secret-key-min-32-characters-long-for-testing-purposes
JWT_REFRESH_SECRET=test-refresh-secret-key-min-32-characters-for-tests
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Test Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Pagination
PAGINATION_DEFAULT_LIMIT=10
PAGINATION_MAX_LIMIT=100

# Minimal Rate Limiting for Tests
# High limits to avoid throttling during tests
THROTTLE_SHORT_TTL=1000
THROTTLE_SHORT_LIMIT=1000
THROTTLE_MEDIUM_TTL=10000
THROTTLE_MEDIUM_LIMIT=5000
THROTTLE_LONG_TTL=60000
THROTTLE_LONG_LIMIT=10000

# Test Logging
# Error level only to reduce noise
LOG_LEVEL=error
LOG_FILE=logs/test.log
LOG_DIR=logs
LOG_FILE_MAX_SIZE=5242880
LOG_FILE_MAX_FILES=3
LOG_TIMESTAMP_FORMAT=YYYY-MM-DD HH:mm:ss

# CORS - Allow All (Testing)
CORS_ORIGIN=*

# Security Headers (Relaxed for Testing)
HELMET_CSP_DEFAULT_SRC=self
HELMET_CSP_STYLE_SRC=self,unsafe-inline
HELMET_CSP_SCRIPT_SRC=self,unsafe-inline
HELMET_CSP_IMG_SRC=self,data:,https:
HELMET_CROSS_ORIGIN_EMBEDDER_POLICY=false

# Health Checks
HEALTH_MEMORY_HEAP_MB=200
HEALTH_MEMORY_RSS_MB=400
HEALTH_DISK_THRESHOLD=0.95
HEALTH_DISK_PATH=/

# Test-Specific Flags
# SKIP_DB_SETUP=false (CI should set to true if handling DB separately)
# CI=false (auto-detected by CI systems)
