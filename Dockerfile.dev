FROM node:20-alpine

WORKDIR /app

# Install dependencies
RUN apk add --no-cache bash

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev)
RUN npm install

# Copy source
COPY . .

# Generate Prisma Client
RUN npx prisma generate

# Expose ports
EXPOSE 3000 9229

# Start in development mode
CMD ["npm", "run", "start:dev"]
